{
  "name": "tinda-agent",
  "version": "1.12.13",
  "description": "TindaAgent - TypeScript web and CLI agent platform",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:web",
    "build:ts": "tsc -p tsconfig.json",
    "build:web": "node scripts/build-web.mjs",
    "start": "node --no-warnings=ExperimentalWarning dist/web/server.bundle.js",
    "start:build": "npm run build && npm start",
    "dev": "tsx src/web/server.ts",
    "doctor": "tsx src/cli/doctor.ts",
    "tinda": "tsx src/cli/main.ts",
    "test": "npm run build && npm run test:session-compat && npm run test:http-features",
    "test:session-compat": "tsx src/cli/sessionCompatSmoke.ts",
    "test:http-features": "tsx src/cli/httpFeatureSmoke.ts"
  },
  "bin": {
    "tinda": "dist/cli/main.js"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "openai": "^6.9.1",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.9.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
